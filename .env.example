# =============================================================================
# Zimbra Backup System - Variables de Entorno
# =============================================================================
# Copiar este archivo a .env y completar los valores reales
# NUNCA commitear el archivo .env al repositorio
#
# IMPORTANTE: Este sistema debe ejecutarse en un servidor de backup
# DIFERENTE al servidor Zimbra. Las variables ZIMBRA_REMOTE_* configuran
# la conexión SSH al servidor Zimbra desde el servidor de backup.
# =============================================================================

# --- Backup Service ---
BACKUP_CONFIG=/config/backup.conf
TZ=America/Argentina/Buenos_Aires

# Clave API interna entre backup-service y web-service
# Generar con: openssl rand -hex 32
BACKUP_API_KEY=change_me_generate_with_openssl_rand_hex_32

# --- Zimbra Remote (MODO REMOTO - RECOMENDADO) ---
# Servidor Zimbra desde el que se extraen los mailboxes via SSH/rsync.
# El backup-service se conecta a este servidor para pull de los mailboxes.
ZIMBRA_REMOTE_HOST=zimbra.example.com
ZIMBRA_REMOTE_USER=zimbrabackup

# --- Remote rsync secundario (opcional, para redundancia offsite) ---
RSYNC_HOST=backup-offsite.example.com
RSYNC_USER=backupuser

# --- Web Service (Fase 2) ---
# Puerto donde exponer la interfaz web
WEB_PORT=8080

# Clave secreta para sesiones Flask
# Generar con: openssl rand -hex 32
WEB_SECRET_KEY=change_me_generate_with_openssl_rand_hex_32

# --- LDAP (Fase 2) ---
LDAP_HOST=ldap://zimbra.example.com
LDAP_PORT=389
LDAP_USE_TLS=false
LDAP_BIND_DN=uid=backup-reader,ou=people,dc=example,dc=com
LDAP_BIND_PASSWORD=change_me_ldap_password
LDAP_BASE_DN=ou=people,dc=example,dc=com
LDAP_USER_FILTER=(mail={username})
LDAP_GROUP_ADMIN=cn=admins,ou=groups,dc=example,dc=com

# --- Demo Auth (SOLO DESARROLLO) ---
# Si DEMO_AUTH=true, usa autenticación fake (no LDAP)
# NO USAR EN PRODUCCIÓN
DEMO_AUTH=false
